# ==============================================================================
# Segments Manager - Environment Configuration (MongoDB Backend)
# ==============================================================================

# ------------------------------------------------------------------------------
# MongoDB Connection (Required)
# ------------------------------------------------------------------------------
# MongoDB connection URL
# Local:  mongodb://localhost:27017
# Auth:   mongodb://user:password@host:27017
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017

# MongoDB database name (optional, default: segments_manager)
MONGODB_DB_NAME=segments_manager

# ------------------------------------------------------------------------------
# Site Configuration (Required)
# ------------------------------------------------------------------------------
# Site IP Prefix Mapping — the single source of truth for configured sites.
# Format: site:first_octet
# Example: site1:192 means site1 uses 192.x.x.x addresses
SITE_PREFIXES=site1:192,site2:193,site3:194

# ------------------------------------------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# API token — REQUIRED (the app fails to start without it). It is the ONLY
# credential: there is no username/password login. Every mutating API call
# (POST/PUT/PATCH/DELETE) must send it as: Authorization: Bearer <API_TOKEN>
# GET requests stay open (the read-only web UI needs no auth). Use a long random
# secret, e.g.  API_TOKEN="$(openssl rand -hex 32)"
API_TOKEN=

# ------------------------------------------------------------------------------
# Connectivity Workflow (Required)
# ------------------------------------------------------------------------------
# Base URL of the Cluster Orchestrator's unified workflows API (api.py in the
# workflows repo). Every segment creation triggers the connectivity workflow
# there (POST /workflows/connectivity) as a best-effort, fire-and-poll-later
# call — segment creation succeeds even if this call fails.
CONNECTIVITY_WORKFLOW_API_URL=http://localhost:8080
