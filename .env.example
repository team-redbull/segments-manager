# ==============================================================================
# VLAN Manager - Environment Configuration (MongoDB Backend)
# ==============================================================================

# ------------------------------------------------------------------------------
# MongoDB Connection (Required)
# ------------------------------------------------------------------------------
# MongoDB connection URL
# Local:  mongodb://localhost:27017
# Auth:   mongodb://user:password@host:27017
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017

# MongoDB database name (optional, default: vlan_manager)
MONGODB_DB_NAME=vlan_manager

# ------------------------------------------------------------------------------
# Site Configuration (Required)
# ------------------------------------------------------------------------------
# Comma-separated list of site names
SITES=site1,site2,site3

# Site IP Prefix Mapping (Required)
# Format: site:first_octet
# Example: site1:192 means site1 uses 192.x.x.x addresses
SITE_PREFIXES=site1:192,site2:193,site3:194

# ------------------------------------------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Authentication (Optional)
# ------------------------------------------------------------------------------
# Web UI login credentials (default: admin/admin — change in production!)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
